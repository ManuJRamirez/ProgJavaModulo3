<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>

<GridPane id="historicoGridPanel" fx:id="historicoGridPanel" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="700.0" stylesheets="@styles.css" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="learning.tokioschool.practicaTresControlStock.HistoricoControlador">

  <columnConstraints>
    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
  </columnConstraints>
  <rowConstraints>
    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
    <RowConstraints maxHeight="-Infinity" minHeight="50.0" prefHeight="50.0" vgrow="SOMETIMES" />
  </rowConstraints>
   <children>
      <TableView id="tablaHistorico" fx:id="tablaHistorico" prefHeight="115.0" prefWidth="253.0" GridPane.columnSpan="2" GridPane.rowSpan="2">
        <columns>
          <TableColumn id="columnaTipoHistorico" fx:id="columnaTipoHistorico" editable="false" maxWidth="200.0" minWidth="200.0" prefWidth="200.0" resizable="false" sortable="false" text="Tipo" />
          <TableColumn id="columnaFechaHistorico" fx:id="columnaFechaHistorico" editable="false" maxWidth="350.0" minWidth="350.0" prefWidth="350.0" resizable="false" sortable="false" text="Fecha" />
            <TableColumn id="columnaStockHistorico" fx:id="columnaStockHistorico" editable="false" maxWidth="150.0" minWidth="150.0" prefWidth="150.0" resizable="false" sortable="false" text="Stock" />
        </columns>
      </TableView>
      <Button id="btnCerrarHistorico" fx:id="btnCerrarHistorico" mnemonicParsing="false" onAction="#btnCerrarHistoricoAction" prefHeight="25.0" prefWidth="250.0" text="Cerrar Histórico" GridPane.columnSpan="2" GridPane.halignment="CENTER" GridPane.rowIndex="2" GridPane.valignment="CENTER" />
   </children>
</GridPane>
